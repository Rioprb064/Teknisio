<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingBottom="16dp"
    android:gravity="center_vertical">

    <!-- News thumbnail -->
    <ImageView
        android:id="@+id/ivNewsImage"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_news_thumb"
        android:src="@drawable/ic_notification"
        android:contentDescription="News Image"/>

    <!-- News text content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:id="@+id/tvNewsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cara agar perabotan mu awet"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1D1D1D"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvNewsDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mari kita pahami bagaimana cara agar..."
            android:textSize="10sp"
            android:textColor="#6B7280"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvNewsDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 April 2026"
            android:textSize="9sp"
            android:textColor="#9CA3AF"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Chevron arrow -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="Open news"
        app:tint="#9CA3AF"/>

</LinearLayout>
