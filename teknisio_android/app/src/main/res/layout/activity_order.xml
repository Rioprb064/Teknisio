<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9F0F4">

    <!-- Scrollable main content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- ── Toolbar ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_back_button"
                    android:gravity="center"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_left"
                        android:contentDescription="Back"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Order Technician"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1D1D1D"/>
            </RelativeLayout>

            <!-- ── Select Category ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Category"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1D1D1D"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:padding="16dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Category 1 -->
                <LinearLayout
                    android:id="@+id/catAC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <FrameLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_cat_icon_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_home"
                            android:contentDescription="AC"
                            app:tint="#2F4273"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AC"
                        android:textSize="11sp"
                        android:textColor="#1D1D1D"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Category 2 -->
                <LinearLayout
                    android:id="@+id/catFridge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <FrameLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_cat_icon_circle">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_notification"
                            android:contentDescription="Fridge"
                            app:tint="#2F4273"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fridge"
                        android:textSize="11sp"
                        android:textColor="#1D1D1D"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Describe Damages ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Describe Damages"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1D1D1D"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etDamageDesc"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@null"
                    android:padding="16dp"
                    android:hint="Describe your furniture damages"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"/>

                <!-- Attachment icons at bottom right -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_profile_placeholder"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Attachment"
                        app:tint="#9CA3AF"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notification"
                        android:contentDescription="Camera"
                        app:tint="#9CA3AF"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Set Schedule ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Schedule"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1D1D1D"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <!-- Date row -->
                <LinearLayout
                    android:id="@+id/rowDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_time_slot"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Calendar"/>
                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Set a date"
                        android:textSize="14sp"
                        android:textColor="#6B7280"/>
                </LinearLayout>

                <!-- Time slots row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Morning -->
                    <LinearLayout
                        android:id="@+id/slotMorning"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_time_slot"
                        android:layout_marginEnd="8dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_home"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="Morning"
                            app:tint="#6B7280"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Morning"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#1D1D1D"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 AM - 11 AM"
                            android:textSize="9sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <!-- Afternoon -->
                    <LinearLayout
                        android:id="@+id/slotAfternoon"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_time_slot_active"
                        android:layout_marginEnd="8dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_home"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="Afternoon"
                            app:tint="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Afternoon"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 PM - 3 PM"
                            android:textSize="9sp"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>

                    <!-- Evening -->
                    <LinearLayout
                        android:id="@+id/slotEvening"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_time_slot">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_home"
                            android:layout_marginBottom="4dp"
                            android:contentDescription="Evening"
                            app:tint="#6B7280"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Evening"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#1D1D1D"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4 PM - 6 PM"
                            android:textSize="9sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- ── Technician Summary Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <!-- Small photo -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivTechSmall"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:layout_marginEnd="12dp"/>

                <!-- Text info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTechName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ahmed Rush"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1D1D1D"
                        android:layout_marginBottom="4dp"/>

                    <!-- Rating stars small -->
                    <LinearLayout
                        android:id="@+id/layoutStarsSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp"/>

                    <!-- Location -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_location_pin"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="Location"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="10sp"
                            android:textColor="#6B7280"/>
                        <TextView
                            android:id="@+id/tvJarak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="± 2 Km"
                            android:textSize="10sp"
                            android:textColor="#6B7280"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- Price -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_notification"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="Price"
                            app:tint="#6B7280"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Price Range"
                            android:textSize="10sp"
                            android:textColor="#6B7280"/>
                        <TextView
                            android:id="@+id/tvPriceSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp50.000 - Rp200.000"
                            android:textSize="10sp"
                            android:textColor="#6B7280"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Specialist icons -->
                <LinearLayout
                    android:id="@+id/layoutSpecSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Sticky Footer: Confirm Order ── -->
    <LinearLayout
        android:id="@+id/footerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_primary"
            android:text="Confirm Order"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
