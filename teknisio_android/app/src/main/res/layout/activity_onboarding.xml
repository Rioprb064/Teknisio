<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF2F8">

    <!-- ViewPager2 for sliding images (takes top 60% of screen) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"/>

    <!-- Bottom section: Logo + Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        android:paddingBottom="32dp">

        <!-- Logo Icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_logo_teknisio"
            android:contentDescription="Teknisio Logo"
            android:layout_marginBottom="16dp"/>

        <!-- TEKNISIO SVG Text -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:src="@drawable/ic_teknisio_text"
            android:contentDescription="TEKNISIO"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp"/>

        <!-- Your Service Solution SVG Text -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:src="@drawable/ic_service_solution_text"
            android:contentDescription="Your Service Solution"
            android:scaleType="fitCenter"
            android:layout_marginBottom="32dp"/>


        <!-- Start Button -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_start_button"
            android:text="Start"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>

</LinearLayout>
