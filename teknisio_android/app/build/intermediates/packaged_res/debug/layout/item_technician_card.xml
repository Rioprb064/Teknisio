<?xml version="1.0" encoding="utf-8"?>
<!-- Technician card for carousel. Width/height set programmatically by adapter for active/inactive -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="111dp"
    android:layout_height="126dp">

    <!-- Photo (ImageView fills the card) -->
    <ImageView
        android:id="@+id/ivTechPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Technician photo"/>

    <!-- Overlay: grey for inactive, replaced by teal in code for active -->
    <View
        android:id="@+id/vOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#8094A5A6"/>

    <!-- Top row: stars + distance (hidden for inactive) -->
    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="top"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Stars -->
        <LinearLayout
            android:id="@+id/layoutStars"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>

        <!-- Distance -->
        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="± 2 Km"
            android:textSize="8sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Bottom content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="8dp">

        <!-- Name -->
        <TextView
            android:id="@+id/tvTechName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>

        <!-- Price (hidden for inactive) -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="7sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- Bottom row: category icons + More Info button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Category icon circles -->
            <LinearLayout
                android:id="@+id/layoutIcons"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

            <!-- More Info button (hidden for inactive) -->
            <TextView
                android:id="@+id/tvMoreInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More Info ›"
                android:textColor="#FFFFFF"
                android:textSize="7sp"
                android:background="#B22F4273"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
