<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6EDF2"
    android:padding="32dp">

    <!-- Logo Area -->
    <LinearLayout
        android:id="@+id/logo_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAFTAR"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#6382D4"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FEE2E2"
        android:textColor="#DC2626"
        android:padding="12dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/logo_area"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tabs Role -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#D1D8E0"
        android:padding="4dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_error_message">

        <Button
            android:id="@+id/btn_tab_customer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:textColor="#384A7E"
            android:text="Customer"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:backgroundTint="@null"/>

        <Button
            android:id="@+id/btn_tab_teknisi"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:textColor="#555555"
            android:text="Teknisi"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:backgroundTint="@null"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tab_container"
        app:layout_constraintBottom_toTopOf="@id/footer_area">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_nama"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:hint="Enter your full name"
                android:textColorHint="#9CA3AF"
                android:textColor="#333333"
                android:inputType="textPersonName"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:hint="Enter your Email"
                android:textColorHint="#9CA3AF"
                android:textColor="#333333"
                android:inputType="textEmailAddress"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- No Telepon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_telepon"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:hint="Enter your phone number"
                android:textColorHint="#9CA3AF"
                android:textColor="#333333"
                android:inputType="phone"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Password Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="8dp"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="48dp"
                    android:hint="Enter your Password"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#333333"
                    android:inputType="textPassword"
                    android:textSize="14sp"/>
                <ImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="Toggle password visibility" />
            </FrameLayout>

            <!-- Alamat -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_alamat"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:hint="Enter your full address"
                android:textColorHint="#9CA3AF"
                android:textColor="#333333"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Deskripsi (Hanya Teknisi) -->
            <LinearLayout
                android:id="@+id/container_deskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skills Description"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/et_deskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:hint="Tell us about your technical skills..."
                    android:textColorHint="#9CA3AF"
                    android:textColor="#333333"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer Area -->
    <LinearLayout
        android:id="@+id/footer_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_primary"
            android:text="Confirm"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            app:backgroundTint="@null"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have account? "
                android:textColor="#444444"
                android:textSize="14sp"/>
                
            <TextView
                android:id="@+id/tv_login_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login now"
                android:textColor="#111111"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
